<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginRight="14dp"
    android:layout_marginLeft="14dp"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="3dp"
        app:cardCornerRadius="3dp"
        app:cardElevation="3dp"
        app:cardUseCompatPadding="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            >

            <ImageView
                android:id="@+id/iv_foto"
                android:layout_width="150dp"
                android:layout_height="220dp"
                android:layout_marginBottom="4dp"
                android:scaleType="centerCrop"
                android:src="@color/colorAccent"
                />

            <TextView
                android:id="@+id/tv_id_lahan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ID Lahan"
                android:layout_marginLeft="14dp"
                android:layout_marginTop="14dp"
                android:layout_marginRight="14dp"
                android:layout_toEndOf="@id/iv_foto"
                />

            <TextView
                android:id="@+id/tv_namapemilik"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_id_lahan"
                android:text="Nama Pemilik"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginLeft="14dp"
                android:layout_marginTop="14dp"
                android:layout_marginRight="14dp"
                android:layout_toEndOf="@id/iv_foto"
                />

            <TextView
                android:id="@+id/tv_luas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_namapemilik"
                android:text="Luas"
                android:textSize="18sp"
                android:layout_marginLeft="14dp"
                android:layout_marginTop="14dp"
                android:layout_marginRight="14dp"
                android:layout_toEndOf="@id/iv_foto"
                />

            <TextView
                android:id="@+id/tv_meter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_luas"
                android:text="Meter"
                android:textSize="18sp"
                android:layout_marginLeft="14dp"
                android:layout_marginTop="14dp"
                android:layout_marginRight="14dp"
                android:layout_toEndOf="@id/iv_foto"
                />

            <TextView
                android:id="@+id/tv_desa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_meter"
                android:text="Desa"
                android:textSize="18sp"
                android:maxLines="2"
                android:layout_marginLeft="14dp"
                android:layout_marginTop="14dp"
                android:layout_marginRight="14dp"
                android:layout_toEndOf="@id/iv_foto"
                />

            <TextView
                android:id="@+id/tv_kecamatan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_desa"
                android:text="Kecamatan"
                android:textSize="18sp"
                android:maxLines="2"
                android:layout_marginLeft="14dp"
                android:layout_marginTop="14dp"
                android:layout_marginRight="14dp"
                android:layout_toEndOf="@id/iv_foto"
                />

            <TextView
                android:id="@+id/tv_latitude"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_kecamatan"
                android:text="Latitude"
                android:textSize="18sp"
                android:layout_marginLeft="14dp"
                android:layout_marginTop="14dp"
                android:layout_marginRight="14dp"
                android:layout_toEndOf="@id/iv_foto"
                />

            <TextView
                android:id="@+id/tv_longtitude"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_latitude"
                android:text="Longtitude"
                android:textSize="18sp"
                android:layout_marginLeft="14dp"
                android:layout_marginTop="14dp"
                android:layout_marginRight="14dp"
                android:layout_toEndOf="@id/iv_foto"
                />

            <!--        <TextView-->
            <!--            android:id="@+id/iv_foto"-->
            <!--            android:layout_width="wrap_content"-->
            <!--            android:layout_height="wrap_content"-->
            <!--            android:text="Foto"-->
            <!--            android:textSize="18sp"-->
            <!--            />-->


        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>


















